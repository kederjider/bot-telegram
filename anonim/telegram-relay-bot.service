[Unit]
Description=telegram-relay-bot
After=network.target

[Service]
Type=simple
User=botuser
WorkingDirectory=/home/botuser/telegram-relay-bot
Environment="PATH=/home/botuser/telegram-relay-bot/venv/bin"
ExecStart=/home/botuser/telegram-relay-bot/venv/bin/python bot.py
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
