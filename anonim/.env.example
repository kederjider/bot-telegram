# Konfigurasi Bot Telegram Relay
# Salin file ini menjadi .env dan isi dengan nilai Anda

# Token bot dari @BotFather (https://t.me/botfather)
BOT_TOKEN=MASUKKAN_TOKEN_BOT_ANDA_DISINI

# Chat ID developer (penerima pesan dari user)
# Dapatkan dari @userinfobot atau identifikasi manual
DEVELOPER_ID=123456789

# Folder penyimpanan arsip (opsional, default: arsip)
ARCHIVE_DIR=arsip
